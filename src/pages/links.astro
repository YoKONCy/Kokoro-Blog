---
/**
 * 友链页 — /links
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getDB } from '@/lib/cloudflare/env';
import { getLinks } from '@/lib/cloudflare/d1';

const db = await getDB(Astro.locals);
const links = db ? await getLinks(db) : [];
---

<BaseLayout title="友链" description="我的朋友们">
  <div class="links-page">
    <div class="glow-card page-header">
      <h1 class="gradient-text">友情链接</h1>
      <p class="description">海内存知己，天涯若比邻。</p>
    </div>

    {links.length > 0 ? (
      <div class="links-grid">
        {links.map(link => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-card glow-card">
            <div class="link-avatar">
              <img src={link.avatar || '/favicon.svg'} alt={link.name} loading="lazy" />
            </div>
            <div class="link-info">
              <h2 class="link-name">{link.name}</h2>
              <p class="link-desc">{link.description || '这个人很懒，什么都没写'}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state glow-card">
        <p>暂时还没有添加友链哦 ~</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .links-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    animation: fade-in-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .page-header {
    text-align: center;
    padding: 3rem 1rem;
  }

  .description {
    color: var(--color-text-dim);
    margin-top: 0.5rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    text-decoration: none;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .link-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .link-avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid oklch(0.65 0.18 280 / 0.3);
    background-color: var(--color-bg);
  }

  .link-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .link-info {
    flex: 1;
    min-width: 0;
  }

  .link-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.3s ease;
  }
  
  .link-card:hover .link-name {
    color: var(--color-primary);
  }

  .link-desc {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-dim);
  }
</style>
