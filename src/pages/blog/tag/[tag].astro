---
/**
 * 标签页 — /blog/tag/[tag]
 * 从 D1 查询指定标签的已发布文章（替代 Content Collections）
 * 支持 ?page=N 分页
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { t } from '@/lib/i18n';
import { formatDate } from '@/lib/date';
import { getPublishedPostsByTag, getAllTags, parseTags } from '@/lib/cloudflare/d1';
import { getDB } from '@/lib/cloudflare/env';

const tag = Astro.params.tag;
if (!tag) {
  return Astro.redirect('/blog', 302);
}

const POSTS_PER_PAGE = 12;
const url = new URL(Astro.request.url);
const currentPage = Math.max(1, parseInt(url.searchParams.get('page') ?? '1', 10) || 1);
const offset = (currentPage - 1) * POSTS_PER_PAGE;

let posts: Awaited<ReturnType<typeof getPublishedPostsByTag>>['items'] = [];
let totalPosts = 0;
let allTags: string[] = [];

try {
  const db = await getDB();
  if (db) {
    const result = await getPublishedPostsByTag(db, tag, POSTS_PER_PAGE, offset);
    posts = result.items;
    totalPosts = result.total;
    allTags = await getAllTags(db);
  }
} catch (e) {
  console.error('[blog/tag] 加载文章列表失败:', e);
}

const totalPages = Math.max(1, Math.ceil(totalPosts / POSTS_PER_PAGE));
---

<BaseLayout title={`#${tag}`} description={`标签「${tag}」下的所有文章`}>
  <div class="blog-page">
    <div class="blog-header">
      <a href="/blog" class="back-link">← {t('blog.allPosts')}</a>
      <h1 class="page-title">
        <span class="tag-icon">#</span>
        <span class="gradient-text">{tag}</span>
      </h1>
      <p class="page-desc">{totalPosts} {t('blog.postsCount')}</p>
    </div>

    <!-- 其他标签 -->
    <div class="tag-filter">
      <a href="/blog" class="tag-pill">{t('blog.allTagsLabel')}</a>
      {allTags.map(tagName => (
        <a href={`/blog/tag/${tagName}`} class:list={['tag-pill', { active: tagName === tag }]}>{tagName}</a>
      ))}
    </div>

    <!-- 文章列表 -->
    <div class="post-list stagger">
      {posts.map(post => <PostCard post={post} activeTag={tag} />)}
    </div>

    <!-- 分页导航 -->
    {totalPages > 1 && (
      <nav class="pagination" aria-label="分页导航">
        {currentPage > 1 ? (
          <a href={`/blog/tag/${tag}?page=${currentPage - 1}`} class="pagination-link prev">← 上一页</a>
        ) : (
          <span class="pagination-link prev disabled">← 上一页</span>
        )}
        <span class="pagination-info">{currentPage} / {totalPages}</span>
        {currentPage < totalPages ? (
          <a href={`/blog/tag/${tag}?page=${currentPage + 1}`} class="pagination-link next">下一页 →</a>
        ) : (
          <span class="pagination-link next disabled">下一页 →</span>
        )}
      </nav>
    )}
  </div>
</BaseLayout>

