---
/**
 * 标签页 — /blog/tag/[tag]
 * 从 D1 查询指定标签的已发布文章（替代 Content Collections）
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/lib/i18n';
import { formatDate } from '@/lib/date';
import { getPublishedPostsByTag, getAllTags, parseTags } from '@/lib/cloudflare/d1';
import { getDB } from '@/lib/cloudflare/env';

const tag = Astro.params.tag;
if (!tag) {
  return Astro.redirect('/blog', 302);
}

let posts: Awaited<ReturnType<typeof getPublishedPostsByTag>> = [];
let allTags: string[] = [];

try {
  const db = await getDB(Astro.locals);
  if (db) {
    posts = await getPublishedPostsByTag(db, tag);
    allTags = await getAllTags(db);
  }
} catch (e) {
  console.error('[blog/tag] 加载文章列表失败:', e);
}
---

<BaseLayout title={`#${tag}`} description={`标签「${tag}」下的所有文章`}>
  <div class="blog-page">
    <div class="blog-header">
      <a href="/blog" class="back-link">← {t('blog.allPosts')}</a>
      <h1 class="page-title">
        <span class="tag-icon">#</span>
        <span class="gradient-text">{tag}</span>
      </h1>
      <p class="page-desc">{posts.length} {t('blog.postsCount')}</p>
    </div>

    <!-- 其他标签 -->
    <div class="tag-filter">
      <a href="/blog" class="tag-pill">{t('blog.allTagsLabel')}</a>
      {allTags.map(tagName => (
        <a href={`/blog/tag/${tagName}`} class:list={['tag-pill', { active: tagName === tag }]}>{tagName}</a>
      ))}
    </div>

    <!-- 文章列表 -->
    <div class="post-list stagger">
      {posts.map(post => {
        const tags = parseTags(post.tags);
        return (
          <a href={`/blog/${post.slug}`} class="post-item glow-card">
            <div class="post-item-main">
              <h2 class="post-item-title">{post.title}</h2>
              <p class="post-item-desc">{post.description}</p>
              <div class="post-item-tags">
                {tags.map(tagName => (
                  <span class:list={['tag-badge', { 'tag-badge-active': tagName === tag }]}>{tagName}</span>
                ))}
              </div>
            </div>
            <div class="post-item-meta">
              <time datetime={post.created_at}>
                {formatDate(new Date(post.created_at))}
              </time>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
