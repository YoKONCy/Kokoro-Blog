---
/**
 * 文章列表页 — /blog
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/lib/i18n';
import { formatDate } from '@/lib/date';
import { getReadingTime } from '@/lib/utils';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 提取所有标签（去重）
const allTags = [...new Set(posts.flatMap(post => post.data.tags))];
---

<BaseLayout title={t('nav.blog')} description="全部文章列表">
  <div class="blog-page">
    <div class="blog-header">
      <h1 class="page-title gradient-text">{t('nav.blog')}</h1>
      <p class="page-desc">共 {posts.length} {t('blog.postsCount')}</p>
    </div>

    <!-- 标签筛选 -->
    <div class="tag-filter">
      <a href="/blog" class="tag-pill active">{t('blog.allTagsLabel')}</a>
      {allTags.map(tag => (
        <a href={`/blog/tag/${tag}`} class="tag-pill">{tag}</a>
      ))}
    </div>

    <!-- 文章列表 -->
    <div class="post-list stagger">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="post-item glow-card">
          <div class="post-item-main">
            <h2 class="post-item-title">{post.data.title}</h2>
            <p class="post-item-desc">{post.data.description}</p>
            <div class="post-item-tags">
              {post.data.tags.map(tag => (
                <span class="tag-badge">{tag}</span>
              ))}
            </div>
          </div>
          <div class="post-item-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            <span class="meta-dot">·</span>
            <span>{getReadingTime(post.body ?? '')} {t('blog.readingTime')}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

