---
/**
 * 文章列表页 — /blog
 * 从 D1 查询已发布文章（替代 Content Collections）
 * 支持 ?page=N 分页
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { t } from '@/lib/i18n';
import { formatDate } from '@/lib/date';
import { getReadingTime } from '@/lib/utils';
import { getPublishedPosts, getAllTags, parseTags } from '@/lib/cloudflare/d1';
import { getDB } from '@/lib/cloudflare/env';

const POSTS_PER_PAGE = 12;
const url = new URL(Astro.request.url);
const currentPage = Math.max(1, parseInt(url.searchParams.get('page') ?? '1', 10) || 1);
const offset = (currentPage - 1) * POSTS_PER_PAGE;

let posts: Awaited<ReturnType<typeof getPublishedPosts>>['items'] = [];
let totalPosts = 0;
let allTags: string[] = [];

try {
  const db = await getDB();
  if (db) {
    const result = await getPublishedPosts(db, POSTS_PER_PAGE, offset);
    posts = result.items;
    totalPosts = result.total;
    allTags = await getAllTags(db);
  }
} catch (e) {
  console.error('[blog] 加载文章列表失败:', e);
}

const totalPages = Math.max(1, Math.ceil(totalPosts / POSTS_PER_PAGE));
---

<BaseLayout title={t('nav.blog')} description="全部文章列表">
  <div class="blog-page">
    <div class="blog-header">
      <h1 class="page-title gradient-text">{t('nav.blog')}</h1>
      <p class="page-desc">共 {totalPosts} {t('blog.postsCount')}</p>
    </div>

    <!-- 标签筛选 -->
    <div class="tag-filter">
      <a href="/blog" class="tag-pill active">{t('blog.allTagsLabel')}</a>
      {allTags.map(tag => (
        <a href={`/blog/tag/${tag}`} class="tag-pill">{tag}</a>
      ))}
    </div>

    <!-- 文章列表 -->
    <div class="post-list stagger">
      {posts.map(post => <PostCard post={post} />)}
    </div>

    <!-- 分页导航 -->
    {totalPages > 1 && (
      <nav class="pagination" aria-label="分页导航">
        {currentPage > 1 ? (
          <a href={`/blog?page=${currentPage - 1}`} class="pagination-link prev">← 上一页</a>
        ) : (
          <span class="pagination-link prev disabled">← 上一页</span>
        )}
        <span class="pagination-info">{currentPage} / {totalPages}</span>
        {currentPage < totalPages ? (
          <a href={`/blog?page=${currentPage + 1}`} class="pagination-link next">下一页 →</a>
        ) : (
          <span class="pagination-link next disabled">下一页 →</span>
        )}
      </nav>
    )}
  </div>
</BaseLayout>

