---
/**
 * 文章列表页 — /blog
 * 从 D1 查询已发布文章（替代 Content Collections）
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/lib/i18n';
import { formatDate } from '@/lib/date';
import { getReadingTime } from '@/lib/utils';
import { getPublishedPosts, parseTags } from '@/lib/cloudflare/d1';
import { getDB } from '@/lib/cloudflare/env';

let posts: Awaited<ReturnType<typeof getPublishedPosts>> = [];
let allTags: string[] = [];

try {
  const db = await getDB();
  if (db) {
    posts = await getPublishedPosts(db);
    // 提取所有标签（去重）
    const tagSet = new Set<string>();
    for (const post of posts) {
      for (const tag of parseTags(post.tags)) {
        tagSet.add(tag);
      }
    }
    allTags = [...tagSet];
  }
} catch (e) {
  console.error('[blog] 加载文章列表失败:', e);
}
---

<BaseLayout title={t('nav.blog')} description="全部文章列表">
  <div class="blog-page">
    <div class="blog-header">
      <h1 class="page-title gradient-text">{t('nav.blog')}</h1>
      <p class="page-desc">共 {posts.length} {t('blog.postsCount')}</p>
    </div>

    <!-- 标签筛选 -->
    <div class="tag-filter">
      <a href="/blog" class="tag-pill active">{t('blog.allTagsLabel')}</a>
      {allTags.map(tag => (
        <a href={`/blog/tag/${tag}`} class="tag-pill">{tag}</a>
      ))}
    </div>

    <!-- 文章列表 -->
    <div class="post-list stagger">
      {posts.map(post => {
        const tags = parseTags(post.tags);
        return (
          <a href={`/blog/${post.slug}`} class="post-item glow-card">
            <div class="post-item-main">
              <h2 class="post-item-title">{post.title}</h2>
              <p class="post-item-desc">{post.description}</p>
              <div class="post-item-tags">
                {tags.map(tag => (
                  <span class="tag-badge">{tag}</span>
                ))}
              </div>
            </div>
            <div class="post-item-meta">
              <time datetime={post.created_at}>
                {formatDate(new Date(post.created_at))}
              </time>
              <span class="meta-dot">·</span>
              <span>{getReadingTime(post.description || '')} {t('blog.readingTime')}</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
