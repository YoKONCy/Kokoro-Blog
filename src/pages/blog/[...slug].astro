---
/**
 * 文章详情页 — /blog/[...slug]
 * 从 D1 查询文章 + 运行时 Markdown 渲染（替代 Content Collections）
 * 样式已提取到 src/styles/post.css
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import CommentSection from '@/components/blog/CommentSection.svelte';
import { t } from '@/lib/i18n';
import { formatDate } from '@/lib/date';
import { getReadingTime } from '@/lib/utils';
import { generateArticleSchema } from '@/lib/seo';
import { getPublishedPostBySlug, getAdjacentPosts, parseTags } from '@/lib/cloudflare/d1';
import { getDB } from '@/lib/cloudflare/env';
import { renderMarkdown } from '@/lib/markdown';

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/blog', 302);
}

const db = await getDB(Astro.locals);
if (!db) {
  return new Response('数据库不可用', { status: 503 });
}

// 检查是否是管理员（允许预览草稿）
let isAdmin = false;
const cookieHeader = Astro.request.headers.get('cookie');
if (cookieHeader) {
  const match = cookieHeader.match(/(?:^|;\s*)session=([^;]*)/);
  if (match) {
    const { validateSession } = await import('@/lib/cloudflare/d1');
    isAdmin = await validateSession(db, decodeURIComponent(match[1]));
  }
}

// 根据身份获取文章
let post;
if (isAdmin) {
  const { getPostBySlug } = await import('@/lib/cloudflare/d1');
  post = await getPostBySlug(db, slug);
} else {
  post = await getPublishedPostBySlug(db, slug);
}

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

// 运行时 Markdown → HTML
const { html: contentHtml } = await renderMarkdown(post.content);

const tags = parseTags(post.tags);
const readingTime = getReadingTime(post.content);

// 获取上一篇/下一篇
const { prev: prevPost, next: nextPost } = await getAdjacentPosts(db, post.created_at);

const pubDate = new Date(post.created_at);
const updatedDate = post.updated_at !== post.created_at ? new Date(post.updated_at) : undefined;

const articleSchema = generateArticleSchema({
  title: post.title,
  description: post.description,
  pubDate,
  updatedDate,
  heroImage: post.hero_image ?? undefined,
  tags,
});
---

<BaseLayout
  title={post.title}
  description={post.description}
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: updatedDate?.toISOString(),
    tags,
  }}
>
  <JsonLd data={articleSchema} />

  <article class="post-page">
    <!-- 文章头部 -->
    <header class="post-header">
      <div class="post-meta-top">
        <time datetime={pubDate.toISOString()}>
          {formatDate(pubDate)}
        </time>
        <span class="meta-sep">·</span>
        <span>{readingTime} {t('blog.readingTime')}</span>
      </div>

      <h1 class="post-title">{post.title}</h1>
      <p class="post-description">{post.description}</p>

      <div class="post-tags">
        {tags.map(tag => (
          <a href={`/blog/tag/${tag}`} class="post-tag">{tag}</a>
        ))}
      </div>
    </header>

    <!-- 题图 -->
    {post.hero_image && (
      <div class="post-hero">
        <img src={post.hero_image} alt={post.title} loading="eager" />
      </div>
    )}

    <!-- 文章正文（运行时渲染的 HTML） -->
    <div class="post-content prose" set:html={contentHtml} />

    <!-- 更新时间 -->
    {updatedDate && (
      <div class="post-updated">
        {t('blog.updatedAt')} {formatDate(updatedDate)}
      </div>
    )}

    <!-- 上一篇/下一篇 -->
    <nav class="post-nav">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="post-nav-link prev">
          <span class="post-nav-label">← {t('blog.prevPost')}</span>
          <span class="post-nav-title">{prevPost.title}</span>
        </a>
      ) : <div />}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} class="post-nav-link next">
          <span class="post-nav-label">{t('blog.nextPost')} →</span>
          <span class="post-nav-title">{nextPost.title}</span>
        </a>
      ) : <div />}
    </nav>

    <!-- 评论区 -->
    <CommentSection postSlug={post.slug} client:visible />
  </article>
</BaseLayout>
