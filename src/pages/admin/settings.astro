---
/**
 * 站点设置 — /admin/settings
 * 分组表单面板：基本信息 / 首页配置 / 评论限流
 */
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { loadSiteConfig } from '@/lib/settings';
import { setSettings } from '@/lib/cloudflare/d1';
import { getDB } from '@/lib/cloudflare/env';

const db = await getDB(Astro.locals);

let message = '';
let messageType = '';

// 处理保存
if (Astro.request.method === 'POST' && db) {
  try {
    const formData = await Astro.request.formData();
    const settings: Record<string, string> = {};

    // 收集所有 setting.* 字段
    for (const [key, value] of formData.entries()) {
      if (key.startsWith('setting.')) {
        settings[key.replace('setting.', '')] = value.toString();
      }
    }

    if (Object.keys(settings).length > 0) {
      await setSettings(db, settings);
      message = '设置已保存';
      messageType = 'success';
    }
  } catch (e) {
    message = '保存失败';
    messageType = 'error';
    console.error('[admin/settings] 保存失败:', e);
  }
}

// 加载当前配置
const config = await loadSiteConfig(db ?? null);
const all = config.getAll();
---

<AdminLayout title="站点设置" description="管理站点基本信息">
  <div class="admin-page">
    <div class="admin-page-header">
      <h1 class="admin-page-title">⚙️ 站点设置</h1>
    </div>

    {message && (
      <div class={`admin-toast admin-toast-${messageType}`}>
        {messageType === 'success' ? '✅' : '❌'} {message}
      </div>
    )}

    <form method="POST">
      <!-- 基本信息 -->
      <div class="admin-settings-panel">
        <h3 class="admin-settings-panel-title">🏠 基本信息</h3>
        <div class="admin-form-group">
          <label class="admin-form-label" for="s-site-title">网站标题</label>
          <input type="text" id="s-site-title" name="setting.site.title" class="admin-form-input" value={all['site.title']} />
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label" for="s-site-logo">Logo 文字</label>
          <input type="text" id="s-site-logo" name="setting.site.logo_text" class="admin-form-input" value={all['site.logo_text']} />
          <p class="admin-form-help">左上角显示的文字，可独立于网站标题</p>
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label" for="s-site-desc">网站描述</label>
          <textarea id="s-site-desc" name="setting.site.description" class="admin-form-textarea" rows="2">{all['site.description']}</textarea>
        </div>
      </div>

      <!-- 首页配置 -->
      <div class="admin-settings-panel">
        <h3 class="admin-settings-panel-title">🎨 首页配置</h3>
        <div class="admin-form-group">
          <label class="admin-form-label" for="s-hero-title">Hero 标题</label>
          <input type="text" id="s-hero-title" name="setting.hero.title" class="admin-form-input" value={all['hero.title']} />
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label" for="s-hero-desc">Hero 副标题</label>
          <input type="text" id="s-hero-desc" name="setting.hero.description" class="admin-form-input" value={all['hero.description']} />
          <p class="admin-form-help">首页打字机效果显示的文字</p>
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label" for="s-footer">页脚文字</label>
          <input type="text" id="s-footer" name="setting.footer.text" class="admin-form-input" value={all['footer.text']} />
        </div>
      </div>

      <!-- 评论限流 -->
      <div class="admin-settings-panel">
        <h3 class="admin-settings-panel-title">🛡️ 评论限流</h3>
        <div class="admin-form-row">
          <div class="admin-form-group">
            <label class="admin-form-label" for="s-tpm-limit">单IP最大条数</label>
            <input type="number" id="s-tpm-limit" name="setting.comment.tpm_limit" class="admin-form-input" value={all['comment.tpm_limit']} min="1" max="100" />
            <p class="admin-form-help">每个窗口期内单个IP可发表的评论数</p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label" for="s-tpm-window">窗口期（秒）</label>
            <input type="number" id="s-tpm-window" name="setting.comment.tpm_window" class="admin-form-input" value={all['comment.tpm_window']} min="60" max="86400" />
            <p class="admin-form-help">默认 600 = 10 分钟</p>
          </div>
        </div>
      </div>

      <div class="admin-settings-actions">
        <button type="submit" class="admin-btn admin-btn-primary" style="width:auto">
          💾 保存设置
        </button>
      </div>
    </form>
  </div>
</AdminLayout>
