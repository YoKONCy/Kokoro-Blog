---
/**
 * ImageLightbox — 通用灯箱
 * 支持放大查看：
 *   1. .prose 内的图片（点击放大）
 *   2. Mermaid 图表 SVG（双击放大）
 *   3. 其他带 data-zoomable 属性的元素
 *
 * 样式位于 src/styles/prose.css
 */
---

<div class="lightbox-overlay" id="lightbox-overlay" transition:persist>
  <img id="lightbox-img" src="" alt="" style="display:none;" />
  <div id="lightbox-html" style="display:none;"></div>
</div>

<script>
  function initLightbox() {
    const overlay = document.getElementById('lightbox-overlay');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxHtml = document.getElementById('lightbox-html') as HTMLDivElement;
    if (!overlay || !lightboxImg || !lightboxHtml) return;

    const win = window as any;
    if (win._lightboxInited) {
      bindAll();
      return;
    }
    win._lightboxInited = true;

    // 关闭灯箱
    function closeLightbox() {
      overlay!.classList.remove('active');
      // 延迟清理内容避免闪烁
      setTimeout(() => {
        lightboxImg.style.display = 'none';
        lightboxImg.src = '';
        lightboxHtml.style.display = 'none';
        lightboxHtml.innerHTML = '';
      }, 300);
    }

    overlay.addEventListener('click', closeLightbox);

    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('active')) {
        closeLightbox();
      }
    });

    bindAll();
  }

  /** 展示图片 */
  function showImage(src: string, alt: string) {
    const overlay = document.getElementById('lightbox-overlay');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxHtml = document.getElementById('lightbox-html') as HTMLDivElement;
    if (!overlay || !lightboxImg || !lightboxHtml) return;

    lightboxHtml.style.display = 'none';
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightboxImg.style.display = '';
    overlay.classList.add('active');
  }

  /** 展示 SVG/HTML 内容 */
  function showHtml(html: string) {
    const overlay = document.getElementById('lightbox-overlay');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxHtml = document.getElementById('lightbox-html') as HTMLDivElement;
    if (!overlay || !lightboxImg || !lightboxHtml) return;

    lightboxImg.style.display = 'none';
    lightboxHtml.innerHTML = html;
    lightboxHtml.style.display = '';
    overlay.classList.add('active');
  }

  function bindAll() {
    // 1. .prose 内所有图片 — 单击放大
    document.querySelectorAll('.prose img').forEach(img => {
      if ((img as any)._lightbox) return;
      (img as any)._lightbox = true;

      img.addEventListener('click', () => {
        showImage((img as HTMLImageElement).src, (img as HTMLImageElement).alt);
      });
    });

    // 2. Mermaid 图表 — 双击放大 SVG（转为 data URL 避免 ID 冲突）
    document.querySelectorAll('.mermaid-chart.rendered').forEach(chart => {
      if ((chart as any)._lightbox) return;
      (chart as any)._lightbox = true;

      (chart as HTMLElement).style.cursor = 'zoom-in';

      chart.addEventListener('dblclick', (e) => {
        e.preventDefault();
        const svg = (chart as HTMLElement).querySelector('svg');
        if (svg) {
          const svgData = new XMLSerializer().serializeToString(svg);
          const dataUrl = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svgData);
          showImage(dataUrl, 'Mermaid diagram');
        }
      });
    });

    // 3. 通用 [data-zoomable] 图片
    document.querySelectorAll('img[data-zoomable]').forEach(img => {
      if ((img as any)._lightbox) return;
      (img as any)._lightbox = true;

      (img as HTMLElement).style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        showImage((img as HTMLImageElement).src, (img as HTMLImageElement).alt);
      });
    });
  }

  // 支持 View Transitions：每次页面加载后重新初始化
  document.addEventListener('astro:page-load', () => {
    initLightbox();

    // 监听 Mermaid 异步渲染完成后重新绑定
    const observer = new MutationObserver((mutations) => {
      for (const m of mutations) {
        if (m.type === 'attributes' && m.attributeName === 'class') {
          const el = m.target as HTMLElement;
          if (el.classList.contains('mermaid-chart') && el.classList.contains('rendered')) {
            bindAll();
            return;
          }
        }
      }
    });

    const prose = document.querySelector('.prose');
    if (prose) {
      observer.observe(prose, { attributes: true, subtree: true, attributeFilter: ['class'] });
    }
  });
</script>
