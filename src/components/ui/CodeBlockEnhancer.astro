---
/**
 * 代码块增强器
 * 在客户端为 Markdown 代码块注入：
 * 1. 客户端语法高亮（highlight.js，因 Cloudflare Workers 禁止 WASM）
 * 2. 语言标签
 * 3. 一键复制按钮
 * 样式已提取到 src/styles/prose.css
 */
---

<!-- highlight.js 资源 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/styles/atom-one-dark.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.11.1/build/highlight.min.js"></script>

<!-- 高亮逻辑：is:inline + data-astro-rerun 确保每次 View Transitions 切页都重新执行 -->
<script is:inline data-astro-rerun>
(function() {
  var blocks = document.querySelectorAll('pre');
  if (!blocks.length) return;

  blocks.forEach(function(block) {
    // 语法高亮（防重复）
    var codeEl = block.querySelector('code');
    if (window.hljs && codeEl && !codeEl.dataset.highlighted) {
      window.hljs.highlightElement(codeEl);
    }

    // 防止 UI 增强重复绑定
    if (block._codeEnhanced) return;
    block._codeEnhanced = true;

    // 创建右上角的操作栏
    var header = document.createElement('div');
    header.className = 'code-header-actions';

    // 解析代码语言
    var lang = '';
    if (block.hasAttribute('data-language')) {
      lang = block.getAttribute('data-language') || '';
    } else if (block.parentElement && block.parentElement.hasAttribute('data-language')) {
      lang = block.parentElement.getAttribute('data-language') || '';
    } else if (codeEl) {
      var match = codeEl.className.match(/language-(\w+)/);
      if (match) lang = match[1];
    }

    // 语言标签
    if (lang) {
      var langSpan = document.createElement('span');
      langSpan.className = 'code-lang';
      langSpan.textContent = lang.toUpperCase();
      header.appendChild(langSpan);
    }

    // 复制按钮
    var copyBtn = document.createElement('button');
    copyBtn.className = 'code-copy-btn';
    var svgIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
    copyBtn.innerHTML = svgIcon;
    copyBtn.setAttribute('aria-label', '复制代码');

    copyBtn.addEventListener('click', function() {
      var code = block.querySelector('code');
      var text = code ? code.innerText : '';
      navigator.clipboard.writeText(text).then(function() {
        copyBtn.innerHTML = '复制成功 (๑•̀ㅂ•́)و✧';
        copyBtn.classList.add('success');
        setTimeout(function() {
          copyBtn.innerHTML = svgIcon;
          copyBtn.classList.remove('success');
        }, 2000);
      }).catch(function() {
        copyBtn.innerHTML = '复制失败 ╥﹏╥';
      });
    });

    header.appendChild(copyBtn);
    block.appendChild(header);
  });
})();
</script>
