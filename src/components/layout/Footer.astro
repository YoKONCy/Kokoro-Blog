---
/**
 * Footer — 网站底部
 */
import { t } from '@/lib/i18n';
import { SITE } from '@/lib/seo';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <!-- 上半部分 -->
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">✦</span>
        <span class="footer-name">{SITE.title}</span>
        <p class="footer-desc">{SITE.description}</p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <h4>{t('footer.nav')}</h4>
          <a href="/">{t('nav.home')}</a>
          <a href="/blog">{t('nav.blog')}</a>
          <a href="/about">{t('nav.about')}</a>
          <a href="/links">{t('nav.links')}</a>
        </div>
        <div class="footer-col">
          <h4>{t('footer.subscribe')}</h4>
          <a href="/rss.xml">RSS Feed</a>
        </div>
      </div>
    </div>

    <!-- 分割线 -->
    <div class="footer-divider"></div>

    <!-- 底部版权 -->
    <div class="footer-bottom">
      <p>© {currentYear} {SITE.author}. {t('footer.copyright')}.</p>
      <p class="footer-powered">{t('footer.poweredBy')} ⚡</p>
    </div>
  </div>
</footer>



