{
	"compatibility_date": "2026-04-23",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"name": "kokoroblog",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "kokoro",
			"database_id": "placeholder"
		}
	]
}